generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String

  // Personal info
  dateOfBirth       DateTime? @db.Date
  hometown          String?
  permanentAddress  String?
  currentAddress    String?
  citizenId         String?
  phone             String?
  socialLink        String?

  // Role & Permissions
  role              Role      @default(STAFF)
  permissionGroupId String?
  permissionGroup   PermissionGroup? @relation(fields: [permissionGroupId], references: [id])

  department    String?
  position      String?
  isActive      Boolean   @default(true)
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  attendances      Attendance[]
  loginHistories   LoginHistory[]
  leaveRequests    LeaveRequest[]
  assignedTodos    TodoItem[]    @relation("TodoAssignee")
  createdTodos     TodoItem[]    @relation("TodoCreator")
  uploadHistories  UploadHistory[]
  claimOrders      ClaimOrder[]
  scoredEmployees  EmployeeScore[] @relation("ScoredBy")
  receivedScores   EmployeeScore[] @relation("ReceivedScore")
  infoChangeRequests InfoChangeRequest[]
  feedbacks        Feedback[]

  // CRM relations
  shopAssignments     ShopAssignment[]  @relation("ShopAssignments")
  prospectAssignments ShopProspect[]    @relation("ProspectAssignments")
}

enum Role {
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

model PermissionGroup {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?

  // === Tổng Quan ===
  canViewDashboard        Boolean @default(true)

  // === Quản lý đơn hàng ===
  canViewOrders           Boolean @default(true)
  canUploadExcel          Boolean @default(true)
  canDeleteOrders         Boolean @default(false)
  canEditStaffNotes       Boolean @default(true)
  canExportOrdersCustomer Boolean @default(false)
  canExportOrdersInternal Boolean @default(false)
  canUseAdvancedFilters   Boolean @default(true)

  // === Tài chính ===
  canViewRevenue          Boolean @default(false)
  canViewCarrierFee       Boolean @default(false)
  canViewFinancePage      Boolean @default(false)
  canViewDashboardFinance Boolean @default(false)
  canManageExpenses       Boolean @default(false)
  canUploadCashbook       Boolean @default(false)
  canManageBudgets        Boolean @default(false)

  // === Chăm sóc đơn Hoãn ===
  canViewDelayed          Boolean @default(true)

  // === Theo dõi đơn Hoàn ===
  canViewReturns          Boolean @default(true)
  canConfirmReturn        Boolean @default(false)

  // === Khiếu nại / Bồi hoàn ===
  canViewClaims           Boolean @default(true)
  canCreateClaim          Boolean @default(true)
  canUpdateClaim          Boolean @default(false)
  canDeleteClaim          Boolean @default(false)
  canViewClaimsTools      Boolean @default(false)
  canViewCompensation     Boolean @default(false)

  // === Công việc ===
  canViewAllTodos         Boolean @default(false)

  // === Chấm công ===
  canViewAllAttendance    Boolean @default(false)
  canEditAttendance       Boolean @default(false)

  // === Nghỉ phép ===
  canApproveLeave         Boolean @default(false)

  // === Tài liệu ===
  canManageDocuments      Boolean @default(false)
  canManageLinks          Boolean @default(false)

  // === Thông báo ===
  canCreateAnnouncement   Boolean @default(false)

  // === Quản trị ===
  canManageUsers          Boolean @default(false)
  canManagePermissions    Boolean @default(false)

  // === CRM ===
  canViewCRM              Boolean @default(true)
  canManageCRM            Boolean @default(false)
  canEditShopInfo         Boolean @default(true)
  canViewAllShops         Boolean @default(false)

  // System flag
  isSystemGroup           Boolean @default(false)

  users         User[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Order {
  id                  String    @id @default(cuid())
  reconciliationCode  String?
  reconciliationDate  DateTime?
  shopName            String?
  customerOrderCode   String?
  requestCode         String    @unique
  status              String
  deliveryStatus      DeliveryStatus @default(PROCESSING)
  createdTime         DateTime?
  pickupTime          DateTime?

  // Financial fields
  codAmount           Decimal   @default(0)
  codOriginal         Decimal   @default(0)
  declaredValue       Decimal   @default(0)
  shippingFee         Decimal   @default(0)
  surcharge           Decimal   @default(0)
  overweightFee       Decimal   @default(0)
  insuranceFee        Decimal   @default(0)
  codServiceFee       Decimal   @default(0)
  returnFee           Decimal   @default(0)
  totalFee            Decimal   @default(0)
  carrierFee          Decimal   @default(0)
  ghsvInsuranceFee    Decimal   @default(0)
  revenue             Decimal   @default(0) // Doanh thu = totalFee - carrierFee

  // Creator info
  creatorShopName     String?
  creatorPhone        String?
  creatorStaff        String?
  creatorAddress      String?
  creatorWard         String?
  creatorDistrict     String?
  creatorProvince     String?

  // Sender info
  senderShopName      String?
  senderPhone         String?
  senderAddress       String?
  senderWard          String?
  senderDistrict      String?
  senderProvince      String?

  // Receiver info
  receiverName        String?
  receiverPhone       String?
  receiverAddress     String?
  receiverWard        String?
  receiverDistrict    String?
  receiverProvince    String?

  // Order details
  deliveryNotes       String?
  productDescription  String?
  paymentConfirmDate  DateTime?
  internalNotes       String?   @db.Text
  publicNotes         String?   @db.Text
  lastUpdated         DateTime?

  // Carrier info
  carrierName         String?
  carrierAccount      String?
  carrierOrderCode    String?
  regionGroup         String?

  // Weight
  customerWeight      Float?
  carrierWeight       Float?
  deliveredDate       DateTime?

  // Operations
  pickupShipper       String?
  deliveryShipper     String?
  orderSource         String?
  partialOrderType    String?
  partialOrderCode    String?
  salesStaff          String?

  // Return tracking fields
  warehouseArrivalDate  DateTime?
  customerConfirmAsked  Boolean    @default(false)
  confirmedAskedBy      String?
  confirmedAskedAt      DateTime?
  customerConfirmed     Boolean    @default(false)
  customerConfirmedBy   String?
  customerConfirmedAt   DateTime?

  // Staff notes (NOT from Excel — editable in app, never overwritten by uploads)
  staffNotes          String?   @db.Text

  // Claim lock — when true, order won't show in Delayed/Returns pages
  claimLocked         Boolean   @default(false)

  // System fields
  importedAt          DateTime  @default(now())
  updatedInDb         DateTime  @updatedAt

  // Relations
  claimOrder          ClaimOrder?
  returnTracking      ReturnTracking?
  todoItems           TodoItem[]
  changeLogs          OrderChangeLog[]

  @@index([status])
  @@index([carrierName])
  @@index([shopName])
  @@index([deliveryStatus])
  @@index([createdTime])
  @@index([lastUpdated])
  @@index([receiverProvince])
  @@index([salesStaff])
  @@index([claimLocked])
  @@index([carrierOrderCode])
  @@index([receiverPhone])
  @@index([regionGroup])
  @@index([partialOrderType])
  @@index([deliveryStatus, createdTime])
  @@index([shopName, deliveryStatus])
  @@index([carrierName, createdTime])
  @@index([salesStaff, createdTime])
  @@index([shopName, createdTime])
  @@index([claimLocked, deliveryStatus, lastUpdated])
  @@index([claimLocked, deliveryStatus, partialOrderType, warehouseArrivalDate])
  @@index([createdTime, revenue])
  @@index([deliveredDate])
  @@index([revenue])
  @@index([creatorShopName, createdTime])
  @@index([pickupTime])
  @@index([paymentConfirmDate])
  @@index([reconciliationDate])
  @@index([codAmount])
  @@index([totalFee])
  @@index([carrierFee])
}

enum DeliveryStatus {
  PROCESSING        // Đang xử lý
  IN_TRANSIT        // Đang chuyển kho giao — Active → Quản lý đơn hàng
  DELIVERING        // Đang giao hàng — Active, BUT also shows in Chăm sóc đơn Hoãn if publicNotes contains delay history
  DELIVERED         // Đã giao hàng — Completed → Quản lý đơn hàng
  RECONCILED        // Đã đối soát giao hàng — Completed → Quản lý đơn hàng
  DELIVERY_DELAYED  // Hoãn giao hàng — Problem → Chăm sóc đơn Hoãn
  RETURN_CONFIRMED  // Xác nhận hoàn — Problem → Chăm sóc đơn Hoãn
  RETURNING_FULL    // Đang chuyển kho trả toàn bộ — Returning → Theo dõi đơn Hoàn
  RETURN_DELAYED    // Hoãn trả hàng — Returning → Theo dõi đơn Hoàn
  RETURNED_FULL     // Đã trả hàng toàn bộ — Completed → Quản lý đơn hàng only
  RETURNED_PARTIAL  // Đã trả hàng một phần — Completed → Quản lý đơn hàng only
}

model UploadHistory {
  id              String    @id @default(cuid())
  fileName        String
  fileSize        Int
  totalRows       Int
  newOrders       Int
  updatedOrders   Int
  skippedRows     Int       @default(0)
  failedRows      Int       @default(0)
  errorLog        String?   @db.Text
  carrierName     String?
  uploadedBy      User      @relation(fields: [uploadedById], references: [id])
  uploadedById    String
  uploadedAt      DateTime  @default(now())
  processingTime  Int?
  totalChanges    Int       @default(0)
  changeLogs      OrderChangeLog[]
}

model ReturnTracking {
  id                      String        @id @default(cuid())
  order                   Order         @relation(fields: [orderId], references: [id])
  orderId                 String        @unique
  returnType              ReturnType
  returnStatus            ReturnStatus  @default(RETURNING)
  returnReason            String?
  warehouseArrivalDate    DateTime?
  returnedToCustomerDate  DateTime?
  returnedByStaff         String?
  notes                   String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
}

enum ReturnType {
  FULL_RETURN
  PARTIAL_RETURN
}

enum ReturnStatus {
  RETURNING
  AT_WAREHOUSE
  RETURNED_TO_CUSTOMER
}

model ClaimOrder {
  id                   String      @id @default(cuid())
  order                Order       @relation(fields: [orderId], references: [id])
  orderId              String      @unique

  // Issue classification
  issueType            IssueType
  issueDescription     String?     @db.Text

  // Dates
  detectedDate         DateTime    @default(now())
  deadline             DateTime?

  // Processing status
  claimStatus          ClaimStatus @default(PENDING)
  processingContent    String?     @db.Text

  // Compensation
  carrierCompensation  Decimal     @default(0)
  customerCompensation Decimal     @default(0)

  // Completion
  isCompleted          Boolean     @default(false)
  completedAt          DateTime?
  completedBy          String?

  // Source tracking
  source               ClaimSource @default(MANUAL)

  // Audit
  createdBy            User        @relation(fields: [createdById], references: [id])
  createdById          String
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  // Status change history
  statusHistory        ClaimStatusHistory[]
  changeLogs           ClaimChangeLog[]

  @@index([issueType])
  @@index([claimStatus])
  @@index([deadline])
  @@index([isCompleted])
  @@index([isCompleted, claimStatus])
  @@index([detectedDate])
  @@index([isCompleted, deadline])
  @@index([isCompleted, detectedDate])
  @@index([claimStatus, detectedDate])
  @@index([issueType, isCompleted])
}

model ClaimStatusHistory {
  id            String       @id @default(cuid())
  claimOrder    ClaimOrder   @relation(fields: [claimOrderId], references: [id], onDelete: Cascade)
  claimOrderId  String
  fromStatus    ClaimStatus?
  toStatus      ClaimStatus
  changedBy     String
  changedAt     DateTime     @default(now())
  note          String?

  @@index([claimOrderId])
  @@index([changedAt])
  @@index([changedBy, changedAt])
}

model ClaimChangeLog {
  id            String     @id @default(cuid())
  claimOrder    ClaimOrder @relation(fields: [claimOrderId], references: [id], onDelete: Cascade)
  claimOrderId  String
  fieldName     String     // "issueType", "issueDescription", "claimStatus", "processingContent", etc.
  oldValue      String?
  newValue      String?
  changedBy     String
  changedAt     DateTime   @default(now())

  @@index([claimOrderId])
  @@index([fieldName])
  @@index([changedAt])
  @@index([fieldName, changedAt])
  @@index([changedBy, changedAt])
}

enum IssueType {
  SLOW_JOURNEY
  SUSPICIOUS
  LOST
  DAMAGED
  OTHER
  FEE_COMPLAINT
}

enum ClaimStatus {
  PENDING
  VERIFYING_CARRIER
  CLAIM_SUBMITTED
  COMPENSATION_REQUESTED
  RESOLVED
  CARRIER_COMPENSATED
  CARRIER_REJECTED
  CUSTOMER_COMPENSATED
  CUSTOMER_REJECTED
}

enum ClaimSource {
  AUTO_SLOW_JOURNEY
  AUTO_INTERNAL_NOTE
  FROM_DELAYED
  FROM_RETURNS
  FROM_ORDERS
  MANUAL
}

model TodoItem {
  id              String      @id @default(cuid())
  title           String
  description     String?     @db.Text
  status          TodoStatus  @default(TODO)
  priority        Priority    @default(MEDIUM)
  dueDate         DateTime?
  sortOrder       Int         @default(0)
  version         Int         @default(0)

  linkedOrderId   String?
  linkedOrder     Order?      @relation(fields: [linkedOrderId], references: [id])
  source          TodoSource  @default(MANUAL)

  comments        TodoComment[]

  assignee        User        @relation("TodoAssignee", fields: [assigneeId], references: [id])
  assigneeId      String
  createdBy       User        @relation("TodoCreator", fields: [createdById], references: [id])
  createdById     String

  completedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
  @@index([assigneeId, status, dueDate])
  @@index([assigneeId, sortOrder])
  @@index([createdById])
}

model TodoComment {
  id          String    @id @default(cuid())
  todoItem    TodoItem  @relation(fields: [todoItemId], references: [id], onDelete: Cascade)
  todoItemId  String
  content     String    @db.Text
  authorName  String
  authorId    String
  createdAt   DateTime  @default(now())

  @@index([todoItemId])
}

enum TodoStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TodoSource {
  MANUAL
  FROM_DELAYED
  FROM_RETURNS
  FROM_CLAIMS
  FROM_ORDERS
  FROM_CRM
}

model Attendance {
  id              String            @id @default(cuid())
  user            User              @relation(fields: [userId], references: [id])
  userId          String
  date            DateTime          @db.Date
  firstLogin      DateTime?
  lastLogout      DateTime?
  totalMinutes    Int               @default(0)
  status          AttendanceStatus  @default(ABSENT)
  isLate          Boolean           @default(false)
  lateMinutes     Int               @default(0)
  isManualEdit    Boolean           @default(false)
  editedBy        String?
  editNote        String?

  @@unique([userId, date])
  @@index([date])
  @@index([userId, date])
  @@index([status])
}

enum AttendanceStatus {
  PRESENT
  HALF_DAY
  ABSENT
  LATE
  ON_LEAVE
  UNAPPROVED_LEAVE
}

model LoginHistory {
  id            String    @id @default(cuid())
  user          User      @relation(fields: [userId], references: [id])
  userId        String
  loginTime     DateTime  @default(now())
  logoutTime    DateTime?
  duration      Int?
  ipAddress     String?
  userAgent     String?
  deviceType    String?
  logoutReason  String?
  lastHeartbeat DateTime?

  @@index([userId, loginTime])
  @@index([logoutTime])
}

// Per-attempt audit log for the credentials login flow. Unlike LoginHistory
// (which only records successes after the credential check passes), this
// table captures BOTH success and failure paths so we can spot brute-force
// patterns by email or IP. Email is stored verbatim to support forensic
// queries even when the email never matches an existing user.
model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ipAddress String
  userAgent String?
  success   Boolean
  reason    String?  // "invalid_password" | "user_not_found" | "rate_limit" | "ok"
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}

model SystemSetting {
  id        String    @id @default(cuid())
  key       String    @unique
  value     String
  updatedBy String?
  updatedAt DateTime  @updatedAt
}

model LeaveRequest {
  id            String        @id @default(cuid())
  user          User          @relation(fields: [userId], references: [id])
  userId        String
  dateFrom      DateTime      @db.Date
  dateTo        DateTime      @db.Date
  totalDays     Int
  reason        String
  leaveStatus   LeaveStatus   @default(PENDING)
  approvedBy    String?
  approvedAt    DateTime?
  rejectedBy    String?
  rejectedAt    DateTime?
  rejectReason  String?
  createdAt     DateTime      @default(now())

  @@index([userId])
  @@index([leaveStatus])
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model EmployeeScore {
  id          String    @id @default(cuid())
  employee    User      @relation("ReceivedScore", fields: [employeeId], references: [id])
  employeeId  String
  scorer      User      @relation("ScoredBy", fields: [scorerId], references: [id])
  scorerId    String
  period      String
  score       Float
  criteria    String?   @db.Text
  comment     String?
  createdAt   DateTime  @default(now())
}

model Document {
  id          String    @id @default(cuid())
  name        String
  fileName    String
  fileSize    Int
  filePath    String
  uploadedBy  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ImportantLink {
  id          String    @id @default(cuid())
  title       String
  url         String
  description String?
  sortOrder   Int       @default(0)
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ============================================================
// FINANCE — Cashbook (from uploaded files)
// ============================================================

model CashbookEntry {
  id              String        @id @default(cuid())
  compositeKey    String        @unique          // receiptCode::groupType
  transactionTime DateTime
  receiptCode     String
  groupType       CashbookGroup
  content         String
  amount          Decimal
  balance         Decimal
  rawCod          Decimal?
  shippingFee     Decimal?
  shopName        String?
  uploadedAt      DateTime      @default(now())
  uploadedBy      String

  @@index([transactionTime])
  @@index([groupType])
  @@index([receiptCode])
  @@index([shopName])
}

enum CashbookGroup {
  COD
  SHOP_PAYOUT
  RECONCILIATION_FEE
  TOP_UP
  COMPENSATION
  COOPERATION_FEE
  OTHER
}

model CashbookUpload {
  id            String    @id @default(cuid())
  fileName      String
  rowCount      Int
  newRows       Int
  duplicateRows Int
  dateFrom      DateTime?
  dateTo        DateTime?
  uploadedBy    String
  uploadedAt    DateTime  @default(now())
}

// ============================================================
// FINANCE — Expenses (manual entries)
// ============================================================

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  isSystem  Boolean   @default(false)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  expenses  Expense[]
  budgets   MonthlyBudget[]
}

model Expense {
  id             String          @id @default(cuid())
  category       ExpenseCategory @relation(fields: [categoryId], references: [id])
  categoryId     String
  title          String
  amount         Decimal 
  date           DateTime        @db.Date
  note           String?
  attachmentUrl  String?
  attachmentName String?
  createdBy      String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([categoryId])
  @@index([date])
}

model MonthlyBudget {
  id           String          @id @default(cuid())
  category     ExpenseCategory @relation(fields: [categoryId], references: [id])
  categoryId   String
  month        DateTime        @db.Date
  budgetAmount Decimal 

  @@unique([categoryId, month])
}

// ============================================================
// ANNOUNCEMENTS — Company-wide notifications from Admin
// ============================================================

model Announcement {
  id              String    @id @default(cuid())
  title           String
  content         String    @db.Text
  attachmentUrl   String?
  attachmentName  String?
  isPinned        Boolean   @default(false)
  createdBy       String
  createdByName   String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  reads           AnnouncementRead[]

  @@index([createdAt])
  @@index([isPinned])
}

model AnnouncementRead {
  id              String       @id @default(cuid())
  announcement    Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  announcementId  String
  userId          String
  readAt          DateTime     @default(now())

  @@unique([announcementId, userId])
  @@index([userId])
}

// ============================================================
// USER PROFILE — Info change requests & Feedback
// ============================================================

model InfoChangeRequest {
  id          String        @id @default(cuid())
  user        User          @relation(fields: [userId], references: [id])
  userId      String
  fieldName   String
  fieldLabel  String
  oldValue    String?
  newValue    String
  status      RequestStatus @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime      @default(now())

  @@index([userId])
  @@index([status])
}

model Feedback {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  userName  String
  content   String   @db.Text
  isRead    Boolean  @default(false)
  readBy    String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================================
// CRM MODELS
// ============================================================

model ShopProfile {
  id              String          @id @default(cuid())
  shopName        String          @unique
  phone           String?
  email           String?
  contactPerson   String?
  zalo            String?
  address         String?
  internalShopNote    String?     @db.Text
  classification  ShopClass?
  startDate       DateTime?       @db.Date

  assignments     ShopAssignment[]
  careLogs        ShopCareLog[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt


}

enum ShopClass {
  VIP
  NORMAL
  NEW
  WARNING
  INACTIVE
}

model ShopAssignment {
  id          String      @id @default(cuid())
  shop        ShopProfile @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId      String
  user        User        @relation("ShopAssignments", fields: [userId], references: [id])
  userId      String
  assignedBy  String
  assignedAt  DateTime    @default(now())

  @@unique([shopId, userId])
  @@index([userId])
  @@index([shopId])
}

model ShopCareLog {
  id              String        @id @default(cuid())
  shop            ShopProfile   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId          String
  contactMethod   ContactMethod
  content         String        @db.Text
  result          CareResult?
  relatedOrderId  String?
  followUpDate    DateTime?     @db.Date
  isAutoLog       Boolean       @default(false)
  authorName      String
  authorId        String
  createdAt       DateTime      @default(now())

  @@index([shopId, createdAt])
}

enum ContactMethod {
  PHONE_CALL
  MESSAGE
  EMAIL
  IN_PERSON
  SYSTEM
  OTHER
}

enum CareResult {
  RESOLVED
  IN_PROGRESS
  WAITING
  UNSATISFIED
  OTHER
}

model ShopProspect {
  id              String          @id @default(cuid())
  shopName        String
  phone           String?
  email           String?
  contactPerson   String?
  zalo            String?
  address         String?
  source          ProspectSource
  sourceDetail    String?
  productType     String?
  estimatedSize   ProspectSize?
  currentCarrier  String?
  stage           PipelineStage   @default(DISCOVERED)
  note            String?         @db.Text
  lostReason      String?
  isLost          Boolean         @default(false)

  assigneeId      String
  assignee        User            @relation("ProspectAssignments", fields: [assigneeId], references: [id])

  contactLogs     ProspectContactLog[]

  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([stage])
  @@index([assigneeId])
  @@index([isLost])
}

enum ProspectSource {
  FACEBOOK
  SHOPEE
  TIKTOK_SHOP
  REFERRAL
  DIRECT
  LANDING_PAGE
  OTHER
}

enum ProspectSize {
  SMALL
  MEDIUM
  LARGE
}

enum PipelineStage {
  DISCOVERED
  CONTACTED
  NEGOTIATING
  TRIAL
  CONVERTED
}

model ProspectContactLog {
  id            String        @id @default(cuid())
  prospect      ShopProspect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  prospectId    String
  contactMethod ContactMethod
  content       String        @db.Text
  result        CareResult?
  followUpDate  DateTime?     @db.Date
  authorName    String
  authorId      String
  createdAt     DateTime      @default(now())

  @@index([prospectId, createdAt])
}

// ============================================================
// ORDER CHANGE TRACKING — Biến động đơn hàng
// ============================================================

enum OrderChangeType {
  STATUS_CHANGE           // 1.  Cột Trạng thái thay đổi (deliveryStatus enum)
  WEIGHT_CHANGE           // 2.  Đổi khối lượng (NVC hoặc KH)
  CARRIER_FEE_CONFIRMED   // 3.  Xác nhận phí NVC thu
  RECIPIENT_CHANGE        // 4.  Đổi thông tin người nhận
  SURCHARGE_CHANGE        // 5.  Đổi nội bộ phụ phí
  SERVICE_FEE_CHANGE      // 6.  Đổi tổng phí dịch vụ
  COD_CONFIRMED           // 7.  Xác nhận đã thanh toán COD
  RETURN_COMPLETED        // 8.  Đã thực hiện trả hàng
  CARRIER_SWITCH          // 9.  Đổi đơn vị vận chuyển
  REDELIVER               // 10. Kéo giao lại đơn hàng
  INTERNAL_STATUS_NOTE    // 11. NV ghi chú đổi trạng thái nội bộ
  RETURN_APPROVED         // 12. Duyệt hoàn / xác nhận duyệt hoàn
  STAFF_NOTE              // 13. Ghi chú ngắn NV (format "TênNV: nội dung")
  COD_AMOUNT_CHANGE       // 14. Đổi tiền hàng / thu hộ
  CLAIM_RELATED           // 15. Khiếu nại / đền bù
  OTHER                   // 16. Khác (fallback)
}

model OrderChangeLog {
  id               String          @id @default(cuid())
  requestCode      String
  order            Order           @relation(fields: [requestCode], references: [requestCode])
  uploadHistoryId  String
  uploadHistory    UploadHistory   @relation(fields: [uploadHistoryId], references: [id])
  changeType       OrderChangeType
  previousValue    String?         @db.Text
  newValue         String?         @db.Text
  changeDetail     String?         @db.Text
  changeTimestamp  DateTime?
  detectedAt       DateTime        @default(now())

  @@index([requestCode])
  @@index([uploadHistoryId])
  @@index([changeType])
  @@index([detectedAt])
  @@index([changeTimestamp])
}
