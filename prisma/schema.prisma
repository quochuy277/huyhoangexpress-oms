generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String

  // Personal info
  dateOfBirth       DateTime? @db.Date
  hometown          String?
  permanentAddress  String?
  currentAddress    String?
  citizenId         String?
  phone             String?
  socialLink        String?

  // Role & Permissions
  role              Role      @default(STAFF)
  permissionGroupId String?
  permissionGroup   PermissionGroup? @relation(fields: [permissionGroupId], references: [id])

  department    String?
  position      String?
  isActive      Boolean   @default(true)
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  attendances      Attendance[]
  loginHistories   LoginHistory[]
  leaveRequests    LeaveRequest[]
  assignedTodos    TodoItem[]    @relation("TodoAssignee")
  createdTodos     TodoItem[]    @relation("TodoCreator")
  uploadHistories  UploadHistory[]
  claimOrders      ClaimOrder[]
  scoredEmployees  EmployeeScore[] @relation("ScoredBy")
  receivedScores   EmployeeScore[] @relation("ReceivedScore")
}

enum Role {
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

model PermissionGroup {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?

  // === Quản lý đơn hàng ===
  canViewOrders           Boolean @default(true)
  canUploadExcel          Boolean @default(true)
  canDeleteOrders         Boolean @default(false)
  canEditStaffNotes       Boolean @default(true)

  // === Tài chính ===
  canViewRevenue          Boolean @default(false)
  canViewCarrierFee       Boolean @default(false)
  canViewFinancePage      Boolean @default(false)
  canViewDashboardFinance Boolean @default(false)

  // === Chăm sóc đơn Hoãn ===
  canViewDelayed          Boolean @default(true)

  // === Theo dõi đơn Hoàn ===
  canViewReturns          Boolean @default(true)
  canConfirmReturn        Boolean @default(false)

  // === Khiếu nại / Bồi hoàn ===
  canViewClaims           Boolean @default(true)
  canCreateClaim          Boolean @default(true)
  canUpdateClaim          Boolean @default(false)

  // === Công việc ===
  canViewAllTodos         Boolean @default(false)

  // === Chấm công ===
  canViewAllAttendance    Boolean @default(false)
  canEditAttendance       Boolean @default(false)
  canScoreEmployees       Boolean @default(false)

  // === Quản trị ===
  canManageUsers          Boolean @default(false)
  canManagePermissions    Boolean @default(false)

  // System flag
  isSystemGroup           Boolean @default(false)

  users         User[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Order {
  id                  String    @id @default(cuid())
  reconciliationCode  String?
  reconciliationDate  DateTime?
  shopName            String?
  customerOrderCode   String?
  requestCode         String    @unique
  status              String
  deliveryStatus      DeliveryStatus @default(PROCESSING)
  createdTime         DateTime?
  pickupTime          DateTime?

  // Financial fields
  codAmount           Decimal   @default(0)
  codOriginal         Decimal   @default(0)
  declaredValue       Decimal   @default(0)
  shippingFee         Decimal   @default(0)
  surcharge           Decimal   @default(0)
  overweightFee       Decimal   @default(0)
  insuranceFee        Decimal   @default(0)
  codServiceFee       Decimal   @default(0)
  returnFee           Decimal   @default(0)
  totalFee            Decimal   @default(0)
  carrierFee          Decimal   @default(0)
  ghsvInsuranceFee    Decimal   @default(0)
  revenue             Decimal   @default(0) // Doanh thu = totalFee - carrierFee

  // Creator info
  creatorShopName     String?
  creatorPhone        String?
  creatorStaff        String?
  creatorAddress      String?
  creatorWard         String?
  creatorDistrict     String?
  creatorProvince     String?

  // Sender info
  senderShopName      String?
  senderPhone         String?
  senderAddress       String?
  senderWard          String?
  senderDistrict      String?
  senderProvince      String?

  // Receiver info
  receiverName        String?
  receiverPhone       String?
  receiverAddress     String?
  receiverWard        String?
  receiverDistrict    String?
  receiverProvince    String?

  // Order details
  deliveryNotes       String?
  productDescription  String?
  paymentConfirmDate  DateTime?
  internalNotes       String?   @db.Text
  publicNotes         String?   @db.Text
  lastUpdated         DateTime?

  // Carrier info
  carrierName         String?
  carrierAccount      String?
  carrierOrderCode    String?
  regionGroup         String?

  // Weight
  customerWeight      Float?
  carrierWeight       Float?
  deliveredDate       DateTime?

  // Operations
  pickupShipper       String?
  deliveryShipper     String?
  orderSource         String?
  partialOrderType    String?
  partialOrderCode    String?
  salesStaff          String?

  // Return tracking fields
  warehouseArrivalDate  DateTime?
  customerConfirmAsked  Boolean    @default(false)
  confirmedAskedBy      String?
  confirmedAskedAt      DateTime?
  customerConfirmed     Boolean    @default(false)
  customerConfirmedBy   String?
  customerConfirmedAt   DateTime?

  // Staff notes (NOT from Excel — editable in app, never overwritten by uploads)
  staffNotes          String?   @db.Text

  // Claim lock — when true, order won't show in Delayed/Returns pages
  claimLocked         Boolean   @default(false)

  // System fields
  importedAt          DateTime  @default(now())
  updatedInDb         DateTime  @updatedAt

  // Relations
  claimOrder          ClaimOrder?
  returnTracking      ReturnTracking?
  todoItems           TodoItem[]

  @@index([status])
  @@index([carrierName])
  @@index([shopName])
  @@index([deliveryStatus])
  @@index([createdTime])
  @@index([lastUpdated])
  @@index([receiverProvince])
  @@index([salesStaff])
  @@index([claimLocked])
}

enum DeliveryStatus {
  PROCESSING        // Đang xử lý
  IN_TRANSIT        // Đang chuyển kho giao — Active → Quản lý đơn hàng
  DELIVERING        // Đang giao hàng — Active, BUT also shows in Chăm sóc đơn Hoãn if publicNotes contains delay history
  DELIVERED         // Đã giao hàng — Completed → Quản lý đơn hàng
  RECONCILED        // Đã đối soát giao hàng — Completed → Quản lý đơn hàng
  DELIVERY_DELAYED  // Hoãn giao hàng — Problem → Chăm sóc đơn Hoãn
  RETURN_CONFIRMED  // Xác nhận hoàn — Problem → Chăm sóc đơn Hoãn
  RETURNING_FULL    // Đang chuyển kho trả toàn bộ — Returning → Theo dõi đơn Hoàn
  RETURN_DELAYED    // Hoãn trả hàng — Returning → Theo dõi đơn Hoàn
  RETURNED_FULL     // Đã trả hàng toàn bộ — Completed → Quản lý đơn hàng only
  RETURNED_PARTIAL  // Đã trả hàng một phần — Completed → Quản lý đơn hàng only
}

model UploadHistory {
  id              String    @id @default(cuid())
  fileName        String
  fileSize        Int
  totalRows       Int
  newOrders       Int
  updatedOrders   Int
  skippedRows     Int       @default(0)
  failedRows      Int       @default(0)
  errorLog        String?   @db.Text
  carrierName     String?
  uploadedBy      User      @relation(fields: [uploadedById], references: [id])
  uploadedById    String
  uploadedAt      DateTime  @default(now())
  processingTime  Int?
}

model ReturnTracking {
  id                      String        @id @default(cuid())
  order                   Order         @relation(fields: [orderId], references: [id])
  orderId                 String        @unique
  returnType              ReturnType
  returnStatus            ReturnStatus  @default(RETURNING)
  returnReason            String?
  warehouseArrivalDate    DateTime?
  returnedToCustomerDate  DateTime?
  returnedByStaff         String?
  notes                   String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
}

enum ReturnType {
  FULL_RETURN
  PARTIAL_RETURN
}

enum ReturnStatus {
  RETURNING
  AT_WAREHOUSE
  RETURNED_TO_CUSTOMER
}

model ClaimOrder {
  id                   String      @id @default(cuid())
  order                Order       @relation(fields: [orderId], references: [id])
  orderId              String      @unique

  // Issue classification
  issueType            IssueType
  issueDescription     String?     @db.Text

  // Dates
  detectedDate         DateTime    @default(now())
  deadline             DateTime?

  // Processing status
  claimStatus          ClaimStatus @default(PENDING)
  processingContent    String?     @db.Text

  // Compensation
  carrierCompensation  Decimal     @default(0)
  customerCompensation Decimal     @default(0)

  // Completion
  isCompleted          Boolean     @default(false)
  completedAt          DateTime?
  completedBy          String?

  // Source tracking
  source               ClaimSource @default(MANUAL)

  // Audit
  createdBy            User        @relation(fields: [createdById], references: [id])
  createdById          String
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  // Status change history
  statusHistory        ClaimStatusHistory[]
  changeLogs           ClaimChangeLog[]

  @@index([issueType])
  @@index([claimStatus])
  @@index([deadline])
  @@index([isCompleted])
}

model ClaimStatusHistory {
  id            String       @id @default(cuid())
  claimOrder    ClaimOrder   @relation(fields: [claimOrderId], references: [id], onDelete: Cascade)
  claimOrderId  String
  fromStatus    ClaimStatus?
  toStatus      ClaimStatus
  changedBy     String
  changedAt     DateTime     @default(now())
  note          String?

  @@index([claimOrderId])
}

model ClaimChangeLog {
  id            String     @id @default(cuid())
  claimOrder    ClaimOrder @relation(fields: [claimOrderId], references: [id], onDelete: Cascade)
  claimOrderId  String
  fieldName     String     // "issueType", "issueDescription", "claimStatus", "processingContent", etc.
  oldValue      String?
  newValue      String?
  changedBy     String
  changedAt     DateTime   @default(now())

  @@index([claimOrderId])
}

enum IssueType {
  SLOW_JOURNEY
  SUSPICIOUS
  LOST
  DAMAGED
  OTHER
}

enum ClaimStatus {
  PENDING
  VERIFYING_CARRIER
  CLAIM_SUBMITTED
  COMPENSATION_REQUESTED
  RESOLVED
  CARRIER_COMPENSATED
  CARRIER_REJECTED
  CUSTOMER_COMPENSATED
  CUSTOMER_REJECTED
}

enum ClaimSource {
  AUTO_SLOW_JOURNEY
  AUTO_INTERNAL_NOTE
  FROM_DELAYED
  FROM_RETURNS
  FROM_ORDERS
  MANUAL
}

model TodoItem {
  id              String      @id @default(cuid())
  title           String
  description     String?     @db.Text
  status          TodoStatus  @default(TODO)
  priority        Priority    @default(MEDIUM)
  dueDate         DateTime?
  sortOrder       Int         @default(0)

  linkedOrderId   String?
  linkedOrder     Order?      @relation(fields: [linkedOrderId], references: [id])
  source          TodoSource  @default(MANUAL)

  comments        TodoComment[]

  assignee        User        @relation("TodoAssignee", fields: [assigneeId], references: [id])
  assigneeId      String
  createdBy       User        @relation("TodoCreator", fields: [createdById], references: [id])
  createdById     String

  completedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
}

model TodoComment {
  id          String    @id @default(cuid())
  todoItem    TodoItem  @relation(fields: [todoItemId], references: [id], onDelete: Cascade)
  todoItemId  String
  content     String    @db.Text
  authorName  String
  authorId    String
  createdAt   DateTime  @default(now())

  @@index([todoItemId])
}

enum TodoStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TodoSource {
  MANUAL
  FROM_DELAYED
  FROM_RETURNS
  FROM_CLAIMS
  FROM_ORDERS
}

model Attendance {
  id              String            @id @default(cuid())
  user            User              @relation(fields: [userId], references: [id])
  userId          String
  date            DateTime          @db.Date
  firstLogin      DateTime?
  lastLogout      DateTime?
  totalMinutes    Int               @default(0)
  status          AttendanceStatus  @default(ABSENT)
  isLate          Boolean           @default(false)
  lateMinutes     Int               @default(0)
  isManualEdit    Boolean           @default(false)
  editedBy        String?
  editNote        String?

  @@unique([userId, date])
  @@index([date])
  @@index([userId, date])
}

enum AttendanceStatus {
  PRESENT
  HALF_DAY
  ABSENT
  LATE
  ON_LEAVE
  UNAPPROVED_LEAVE
}

model LoginHistory {
  id            String    @id @default(cuid())
  user          User      @relation(fields: [userId], references: [id])
  userId        String
  loginTime     DateTime  @default(now())
  logoutTime    DateTime?
  duration      Int?
  ipAddress     String?
  userAgent     String?
  deviceType    String?
  logoutReason  String?

  @@index([userId, loginTime])
}

model SystemSetting {
  id        String    @id @default(cuid())
  key       String    @unique
  value     String
  updatedBy String?
  updatedAt DateTime  @updatedAt
}

model LeaveRequest {
  id            String        @id @default(cuid())
  user          User          @relation(fields: [userId], references: [id])
  userId        String
  dateFrom      DateTime      @db.Date
  dateTo        DateTime      @db.Date
  totalDays     Int
  reason        String
  leaveStatus   LeaveStatus   @default(PENDING)
  approvedBy    String?
  approvedAt    DateTime?
  rejectedBy    String?
  rejectedAt    DateTime?
  rejectReason  String?
  createdAt     DateTime      @default(now())

  @@index([userId])
  @@index([leaveStatus])
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model EmployeeScore {
  id          String    @id @default(cuid())
  employee    User      @relation("ReceivedScore", fields: [employeeId], references: [id])
  employeeId  String
  scorer      User      @relation("ScoredBy", fields: [scorerId], references: [id])
  scorerId    String
  period      String
  score       Float
  criteria    String?   @db.Text
  comment     String?
  createdAt   DateTime  @default(now())
}

model Document {
  id          String    @id @default(cuid())
  name        String
  fileName    String
  fileSize    Int
  filePath    String
  uploadedBy  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ImportantLink {
  id          String    @id @default(cuid())
  title       String
  url         String
  description String?
  sortOrder   Int       @default(0)
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ============================================================
// FINANCE — Cashbook (from uploaded files)
// ============================================================

model CashbookEntry {
  id              String        @id @default(cuid())
  transactionTime DateTime
  receiptCode     String        @unique
  groupType       CashbookGroup
  content         String
  amount          Decimal 
  balance         Decimal 
  rawCod          Decimal?
  shippingFee     Decimal?
  shopName        String?
  uploadedAt      DateTime      @default(now())
  uploadedBy      String

  @@index([transactionTime])
  @@index([groupType])
  @@index([receiptCode])
}

enum CashbookGroup {
  COD
  SHOP_PAYOUT
  RECONCILIATION_FEE
  TOP_UP
  COMPENSATION
  COOPERATION_FEE
  OTHER
}

model CashbookUpload {
  id            String    @id @default(cuid())
  fileName      String
  rowCount      Int
  newRows       Int
  duplicateRows Int
  dateFrom      DateTime?
  dateTo        DateTime?
  uploadedBy    String
  uploadedAt    DateTime  @default(now())
}

// ============================================================
// FINANCE — Expenses (manual entries)
// ============================================================

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  isSystem  Boolean   @default(false)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  expenses  Expense[]
  budgets   MonthlyBudget[]
}

model Expense {
  id             String          @id @default(cuid())
  category       ExpenseCategory @relation(fields: [categoryId], references: [id])
  categoryId     String
  title          String
  amount         Decimal 
  date           DateTime        @db.Date
  note           String?
  attachmentUrl  String?
  attachmentName String?
  createdBy      String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([categoryId])
  @@index([date])
}

model MonthlyBudget {
  id           String          @id @default(cuid())
  category     ExpenseCategory @relation(fields: [categoryId], references: [id])
  categoryId   String
  month        DateTime        @db.Date
  budgetAmount Decimal 

  @@unique([categoryId, month])
}
