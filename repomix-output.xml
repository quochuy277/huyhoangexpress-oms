) {
  try {
    const session = await auth();
    if (!session?.user) {
      return NextResponse.json({ error: "Chưa đăng nhập" }, { status: 401 });
    }

    const { id } = await params;
    const body = await req.json();
    const {
      claimStatus,
      processingContent,
      carrierCompensation,
      customerCompensation,
      deadline,
      isCompleted,
