<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Phân Tích Hoãn Giao Hàng</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg-primary: #0f1117;
  --bg-secondary: #1a1d27;
  --bg-card: #222537;
  --bg-card-hover: #2a2e42;
  --accent: #ff6b35;
  --accent-glow: rgba(255,107,53,0.15);
  --accent-2: #ffa726;
  --danger: #ef4444;
  --danger-bg: rgba(239,68,68,0.12);
  --warning: #f59e0b;
  --warning-bg: rgba(245,158,11,0.12);
  --safe: #22c55e;
  --safe-bg: rgba(34,197,94,0.12);
  --text: #e8eaed;
  --text-dim: #9ca3af;
  --text-muted: #6b7280;
  --border: rgba(255,255,255,0.06);
  --border-accent: rgba(255,107,53,0.25);
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Be Vietnam Pro',sans-serif;background:var(--bg-primary);color:var(--text);min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background:
  linear-gradient(rgba(255,107,53,0.02) 1px, transparent 1px),
  linear-gradient(90deg, rgba(255,107,53,0.02) 1px, transparent 1px);
  background-size:60px 60px;pointer-events:none;z-index:0;}
.container{max-width:1500px;margin:0 auto;padding:24px;position:relative;z-index:1;}

/* Header */
.header{text-align:center;padding:48px 0 32px;position:relative;}
.header::after{content:'';position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:120px;height:2px;background:linear-gradient(90deg,transparent,var(--accent),transparent);}
.header h1{font-size:28px;font-weight:800;letter-spacing:-0.5px;
  background:linear-gradient(135deg,#fff,var(--accent));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.header p{color:var(--text-dim);margin-top:8px;font-size:14px;font-weight:300;}

/* Upload zone */
.upload-zone{margin:40px auto;max-width:600px;border:2px dashed var(--border-accent);border-radius:16px;padding:48px 32px;text-align:center;cursor:pointer;transition:all 0.3s;background:var(--bg-secondary);position:relative;overflow:hidden;}
.upload-zone::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at center, var(--accent-glow), transparent 70%);opacity:0;transition:opacity 0.3s;}
.upload-zone:hover{border-color:var(--accent);transform:translateY(-2px);}
.upload-zone:hover::before{opacity:1;}
.upload-zone.dragover{border-color:var(--accent);background:rgba(255,107,53,0.05);}
.upload-zone.dragover::before{opacity:1;}
.upload-icon{font-size:48px;margin-bottom:12px;filter:grayscale(0.3);}
.upload-zone h3{font-size:16px;font-weight:600;margin-bottom:4px;position:relative;}
.upload-zone p{color:var(--text-muted);font-size:13px;position:relative;}
.upload-zone input{display:none;}
.file-name{margin-top:12px;color:var(--accent);font-weight:500;font-size:13px;position:relative;}

/* Loading */
.loading{display:none;text-align:center;padding:40px;}
.loading.active{display:block;}
.spinner{width:40px;height:40px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin 0.8s linear infinite;margin:0 auto 16px;}
@keyframes spin{to{transform:rotate(360deg)}}

/* Stats row */
.stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin:32px 0;}
.stat-card{background:var(--bg-card);border-radius:12px;padding:20px;border:1px solid var(--border);position:relative;overflow:hidden;}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.stat-card.total::before{background:linear-gradient(90deg,var(--accent),var(--accent-2));}
.stat-card.danger::before{background:var(--danger);}
.stat-card.warning::before{background:var(--warning);}
.stat-card.safe::before{background:var(--safe);}
.stat-label{font-size:12px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;font-weight:500;}
.stat-value{font-size:32px;font-weight:800;margin-top:4px;letter-spacing:-1px;}
.stat-card.total .stat-value{color:var(--accent);}
.stat-card.danger .stat-value{color:var(--danger);}
.stat-card.warning .stat-value{color:var(--warning);}
.stat-card.safe .stat-value{color:var(--safe);}
.stat-sub{font-size:11px;color:var(--text-muted);margin-top:2px;}

/* Chart area */
.chart-section{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin:24px 0;}
.chart-card{background:var(--bg-card);border-radius:12px;padding:20px;border:1px solid var(--border);}
.chart-card h3{font-size:14px;font-weight:600;margin-bottom:16px;color:var(--text-dim);}
.bar-chart{display:flex;flex-direction:column;gap:8px;}
.bar-row{display:flex;align-items:center;gap:10px;}
.bar-label{width:160px;font-size:12px;color:var(--text-dim);text-align:right;flex-shrink:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.bar-track{flex:1;height:24px;background:rgba(255,255,255,0.04);border-radius:6px;overflow:hidden;position:relative;}
.bar-fill{height:100%;border-radius:6px;transition:width 0.8s cubic-bezier(0.25,0.46,0.45,0.94);display:flex;align-items:center;justify-content:flex-end;padding-right:8px;font-size:11px;font-weight:600;min-width:32px;}
.bar-fill.accent{background:linear-gradient(90deg,var(--accent),var(--accent-2));}
.bar-fill.danger{background:linear-gradient(90deg,#dc2626,#ef4444);}
.bar-fill.warning{background:linear-gradient(90deg,#d97706,#f59e0b);}
.bar-fill.safe{background:linear-gradient(90deg,#16a34a,#22c55e);}

/* Filter panel */
.filter-panel{background:var(--bg-card);border-radius:12px;padding:20px;border:1px solid var(--border);margin:24px 0 16px;}
.filter-panel h3{font-size:14px;font-weight:600;margin-bottom:16px;color:var(--text-dim);}
.filter-grid{display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr 1fr;gap:12px;align-items:end;}
.filter-group{display:flex;flex-direction:column;gap:4px;}
.filter-group label{font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;font-weight:500;}
.filter-select,.filter-input{padding:9px 12px;border-radius:8px;border:1px solid var(--border);background:var(--bg-secondary);color:var(--text);font-size:13px;font-family:inherit;outline:none;transition:border-color 0.2s;width:100%;}
.filter-select:focus,.filter-input:focus{border-color:var(--accent);}
.filter-select option{background:var(--bg-secondary);color:var(--text);}
.filter-input::placeholder{color:var(--text-muted);}
.filter-bottom{display:flex;align-items:center;justify-content:space-between;margin-top:14px;flex-wrap:wrap;gap:10px;}
.risk-filters{display:flex;gap:8px;flex-wrap:wrap;align-items:center;}
.risk-filters span{font-size:12px;color:var(--text-muted);margin-right:4px;}
.filter-btn{padding:7px 14px;border-radius:8px;border:1px solid var(--border);background:var(--bg-secondary);color:var(--text-dim);font-size:12px;font-family:inherit;cursor:pointer;transition:all 0.2s;font-weight:500;}
.filter-btn:hover,.filter-btn.active{background:var(--accent);color:#fff;border-color:var(--accent);}
.btn-reset{padding:9px 16px;border-radius:8px;border:1px solid var(--border);background:var(--bg-secondary);color:var(--text-dim);font-size:12px;font-family:inherit;cursor:pointer;transition:all 0.2s;font-weight:500;white-space:nowrap;}
.btn-reset:hover{border-color:var(--accent);color:var(--accent);}
.export-btn{padding:9px 20px;border-radius:8px;border:none;background:linear-gradient(135deg,var(--accent),var(--accent-2));color:#fff;font-size:13px;font-family:inherit;cursor:pointer;font-weight:600;transition:all 0.2s;letter-spacing:0.3px;white-space:nowrap;}
.export-btn:hover{transform:translateY(-1px);box-shadow:0 4px 20px rgba(255,107,53,0.3);}

/* Table */
.table-wrapper{overflow-x:auto;border-radius:12px;border:1px solid var(--border);background:var(--bg-card);}
table{width:100%;border-collapse:collapse;font-size:13px;}
thead{position:sticky;top:0;z-index:2;}
th{background:var(--bg-secondary);padding:12px 10px;text-align:left;font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);border-bottom:2px solid var(--border);white-space:nowrap;cursor:pointer;user-select:none;}
th:hover{color:var(--accent);}
th .sort-icon{margin-left:4px;opacity:0.4;font-size:10px;}
th.sorted .sort-icon{opacity:1;color:var(--accent);}
td{padding:10px 10px;border-bottom:1px solid var(--border);vertical-align:top;}
tr:hover td{background:var(--bg-card-hover);}
tr.risk-high td{border-left:3px solid var(--danger);}
tr.risk-medium td{border-left:3px solid var(--warning);}
tr.risk-low td{border-left:3px solid var(--safe);}

.risk-badge{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;letter-spacing:0.3px;}
.risk-badge.high{background:var(--danger-bg);color:var(--danger);}
.risk-badge.medium{background:var(--warning-bg);color:var(--warning);}
.risk-badge.low{background:var(--safe-bg);color:var(--safe);}
.risk-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;}
.risk-badge.high .risk-dot{background:var(--danger);}
.risk-badge.medium .risk-dot{background:var(--warning);}
.risk-badge.low .risk-dot{background:var(--safe);}

.delay-count{display:inline-flex;align-items:center;justify-content:center;min-width:28px;height:28px;border-radius:8px;font-weight:700;font-size:14px;}
.delay-count.dc-high{background:var(--danger-bg);color:var(--danger);}
.delay-count.dc-med{background:var(--warning-bg);color:var(--warning);}
.delay-count.dc-low{background:var(--safe-bg);color:var(--safe);}

.reason-tag{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;margin:2px 2px;background:rgba(255,255,255,0.05);color:var(--text-dim);line-height:1.5;}

.timeline{font-size:11px;color:var(--text-dim);line-height:1.7;}
.timeline-item{padding-left:14px;position:relative;margin-bottom:2px;}
.timeline-item::before{content:'';position:absolute;left:0;top:7px;width:6px;height:6px;border-radius:50%;background:var(--warning);}

.status-badge{padding:3px 10px;border-radius:20px;font-size:11px;font-weight:500;}
.status-badge.delivering{background:rgba(59,130,246,0.12);color:#60a5fa;}
.status-badge.delayed{background:var(--warning-bg);color:var(--warning);}

.results-section{display:none;}
.results-section.active{display:block;}

/* Order detail cell */
.order-detail{font-size:11px;line-height:1.6;color:var(--text-dim);min-width:230px;position:relative;}
.order-detail .od-line{margin-bottom:1px;}
.order-detail .od-label{color:var(--text-muted);font-weight:600;}
.order-detail .od-value{color:var(--text);}
.copy-btn{display:inline-flex;align-items:center;gap:4px;margin-top:6px;padding:3px 10px;border-radius:5px;border:1px solid var(--border);background:var(--bg-secondary);color:var(--text-dim);font-size:10px;font-family:inherit;cursor:pointer;transition:all 0.2s;}
.copy-btn:hover{border-color:var(--accent);color:var(--accent);}
.copy-btn.copied{border-color:var(--safe);color:var(--safe);}

/* Pagination */
.pagination{display:flex;align-items:center;justify-content:center;gap:8px;margin-top:16px;padding:16px 0;}
.page-btn{padding:6px 12px;border-radius:6px;border:1px solid var(--border);background:var(--bg-secondary);color:var(--text-dim);font-size:12px;font-family:inherit;cursor:pointer;transition:all 0.2s;}
.page-btn:hover,.page-btn.active{background:var(--accent);color:#fff;border-color:var(--accent);}
.page-btn:disabled{opacity:0.3;cursor:not-allowed;}
.page-info{font-size:12px;color:var(--text-muted);}

td.reason-cell{max-width:260px;}
td.timeline-cell{max-width:250px;}
.no-data{text-align:center;padding:40px;color:var(--text-muted);font-size:14px;}

/* Toast */
.toast{position:fixed;bottom:24px;right:24px;padding:10px 20px;border-radius:8px;background:var(--safe);color:#fff;font-size:13px;font-weight:500;z-index:999;opacity:0;transform:translateY(10px);transition:all 0.3s;pointer-events:none;}
.toast.show{opacity:1;transform:translateY(0);}

@media(max-width:1100px){.filter-grid{grid-template-columns:1fr 1fr;}}
@media(max-width:900px){.chart-section{grid-template-columns:1fr;}.stats-row{grid-template-columns:repeat(2,1fr);}.filter-grid{grid-template-columns:1fr;}}
@media(max-width:600px){.container{padding:12px;}.header h1{font-size:20px;}.stats-row{grid-template-columns:1fr 1fr;}.bar-label{width:100px;font-size:11px;}}
</style>
</head>
<body>

<div class="container">
  <div class="header">
    <h1>📦 Phân Tích Hoãn Giao Hàng</h1>
    <p>Upload file quản lý đơn hàng (.xlsx) để phân tích tình trạng hoãn giao</p>
  </div>

  <div class="upload-zone" id="uploadZone">
    <div class="upload-icon">📁</div>
    <h3>Kéo thả file Excel vào đây</h3>
    <p>hoặc bấm để chọn file (.xlsx, .xls)</p>
    <input type="file" id="fileInput" accept=".xlsx,.xls">
    <div class="file-name" id="fileName"></div>
  </div>

  <div class="loading" id="loading">
    <div class="spinner"></div>
    <p style="color:var(--text-dim);font-size:14px;">Đang phân tích dữ liệu...</p>
  </div>

  <div class="results-section" id="results">
    <div class="stats-row" id="statsRow"></div>

    <div class="chart-section">
      <div class="chart-card">
        <h3>📊 Phân bố số lần hoãn giao</h3>
        <div class="bar-chart" id="delayChart"></div>
      </div>
      <div class="chart-card">
        <h3>📋 Top lý do hoãn giao</h3>
        <div class="bar-chart" id="reasonChart"></div>
      </div>
    </div>

    <!-- Filter Panel -->
    <div class="filter-panel">
      <h3>🔍 Tìm kiếm &amp; Lọc</h3>
      <div class="filter-grid">
        <div class="filter-group">
          <label>Tìm kiếm</label>
          <input class="filter-input" type="text" id="searchBox" placeholder="Mã đơn, người nhận, SĐT...">
        </div>
        <div class="filter-group">
          <label>Cửa hàng</label>
          <select class="filter-select" id="filterShop"><option value="">Tất cả</option></select>
        </div>
        <div class="filter-group">
          <label>Trạng thái</label>
          <select class="filter-select" id="filterStatus"><option value="">Tất cả</option></select>
        </div>
        <div class="filter-group">
          <label>Số lần hoãn</label>
          <select class="filter-select" id="filterDelayCount">
            <option value="">Tất cả</option>
            <option value="1">1 lần</option>
            <option value="2">2 lần</option>
            <option value="3">3 lần</option>
            <option value="4+">4+ lần</option>
          </select>
        </div>
        <div class="filter-group">
          <label>Lý do hoãn giao</label>
          <select class="filter-select" id="filterReason"><option value="">Tất cả</option></select>
        </div>
      </div>
      <div class="filter-bottom">
        <div class="risk-filters">
          <span>Nguy cơ:</span>
          <button class="filter-btn active" data-filter="all">Tất cả</button>
          <button class="filter-btn" data-filter="high">🔴 Cao</button>
          <button class="filter-btn" data-filter="medium">🟡 Trung bình</button>
          <button class="filter-btn" data-filter="low">🟢 Thấp</button>
        </div>
        <div style="display:flex;gap:8px;">
          <button class="btn-reset" id="btnReset">↻ Đặt lại bộ lọc</button>
          <button class="export-btn" id="exportBtn">⬇ Xuất Excel</button>
        </div>
      </div>
    </div>

    <!-- Table -->
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th data-sort="stt">STT <span class="sort-icon">▼</span></th>
            <th data-sort="maYC">Mã Yêu Cầu <span class="sort-icon">▼</span></th>
            <th data-sort="shop">Cửa Hàng <span class="sort-icon">▼</span></th>
            <th>Thông Tin Đơn Hàng</th>
            <th data-sort="status">Trạng Thái <span class="sort-icon">▼</span></th>
            <th data-sort="delayCount" class="sorted">Số Lần Hoãn <span class="sort-icon">▼</span></th>
            <th data-sort="daysAge">Ngày Tạo Đơn <span class="sort-icon">▼</span></th>
            <th>Lý Do Hoãn Giao</th>
            <th>Chi Tiết Hoãn Giao</th>
            <th data-sort="riskScore">Nguy Cơ <span class="sort-icon">▼</span></th>
            <th data-sort="cod">Thu Hộ (VND) <span class="sort-icon">▼</span></th>
          </tr>
        </thead>
        <tbody id="tableBody"></tbody>
      </table>
    </div>
    <div class="pagination" id="pagination"></div>
  </div>
</div>

<div class="toast" id="toast">✓ Đã copy vào bộ nhớ tạm</div>

<script>
let allOrders = [];
let filteredOrders = [];
let currentSort = { key: 'delayCount', dir: 'desc' };
let currentRiskFilter = 'all';
let currentPage = 1;
const PAGE_SIZE = 20;

// ===== UPLOAD =====
const uploadZone = document.getElementById('uploadZone');
const fileInput = document.getElementById('fileInput');
uploadZone.addEventListener('click', () => fileInput.click());
uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('dragover'); });
uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('dragover'));
uploadZone.addEventListener('drop', e => { e.preventDefault(); uploadZone.classList.remove('dragover'); if (e.dataTransfer.files.length) handleFile(e.dataTransfer.files[0]); });
fileInput.addEventListener('change', e => { if (e.target.files.length) handleFile(e.target.files[0]); });

function handleFile(file) {
  document.getElementById('fileName').textContent = '📄 ' + file.name;
  document.getElementById('loading').classList.add('active');
  document.getElementById('results').classList.remove('active');
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const wb = XLSX.read(e.target.result, { type: 'array' });
      const ws = wb.Sheets[wb.SheetNames[0]];
      const data = XLSX.utils.sheet_to_json(ws, { defval: '' });
      processData(data);
    } catch (err) { alert('Lỗi đọc file: ' + err.message); }
    document.getElementById('loading').classList.remove('active');
  };
  reader.readAsArrayBuffer(file);
}

// ===== PROCESS =====
function processData(rows) {
  const colMap = detectColumns(rows[0] || {});
  allOrders = [];

  rows.forEach((row, idx) => {
    const ghiChu = String(row[colMap.ghiChuCK] || '');
    const trangThai = String(row[colMap.trangThai] || '');
    if (!ghiChu.includes('Hoãn giao hàng') && !trangThai.includes('Hoãn')) return;

    const delays = parseDelays(ghiChu);
    const reasons = extractReasons(ghiChu);
    const uniqueReasons = [...new Set(reasons)];
    const delayCount = Math.max(delays.length, countDelaysInNote(ghiChu));
    const createdDate = parseViDate(String(row[colMap.thoiGianTao] || ''));
    const daysAge = createdDate ? Math.floor((Date.now() - createdDate.getTime()) / 86400000) : 0;
    const risk = assessRisk(delayCount, uniqueReasons, daysAge, trangThai);

    const addrParts = [String(row[colMap.address]||''), String(row[colMap.ward]||''), String(row[colMap.district]||''), String(row[colMap.province]||'')].filter(Boolean);

    allOrders.push({
      stt: idx + 1,
      maYC: String(row[colMap.maYC] || ''),
      maDonKH: String(row[colMap.maDonKH] || ''),
      maDonDT: String(row[colMap.carrierCode] || ''),
      shop: String(row[colMap.shop] || ''),
      receiver: String(row[colMap.receiver] || ''),
      phone: String(row[colMap.phone] || ''),
      address: String(row[colMap.address] || ''),
      ward: String(row[colMap.ward] || ''),
      district: String(row[colMap.district] || ''),
      province: String(row[colMap.province] || ''),
      fullAddress: addrParts.join(' - '),
      status: trangThai,
      cod: parseNumber(row[colMap.cod]),
      createdDate: String(row[colMap.thoiGianTao] || ''),
      pickupDate: String(row[colMap.pickupDate] || ''),
      lastUpdate: String(row[colMap.lastUpdate] || ''),
      ghiChu, delayCount, delays, reasons, uniqueReasons, daysAge, risk,
      riskScore: risk === 'high' ? 3 : risk === 'medium' ? 2 : 1
    });
  });

  sortOrders('delayCount', 'desc');
  populateFilterDropdowns();
  applyFilters();
  renderStats();
  renderCharts();
  document.getElementById('results').classList.add('active');
}

function detectColumns(sample) {
  const keys = Object.keys(sample);
  const find = (...patterns) => keys.find(k => patterns.some(p => k.toLowerCase().includes(p.toLowerCase()))) || '';
  // For receiver-side phone/address, exclude columns with Tạo/Gửi
  const phoneCol = keys.find(k => /Số Điện Thoại/i.test(k) && !/Tạo|Gửi/i.test(k)) || find('Số Điện Thoại');
  const addressCol = keys.find(k => /^Địa Chỉ$/i.test(k.trim())) || keys.find(k => /Địa Chỉ/i.test(k) && !/Tạo|Gửi/i.test(k)) || '';
  return {
    ghiChuCK: find('Ghi Chú Công Khai', 'Ghi chú công khai'),
    trangThai: find('Trạng Thái', 'Trạng thái'),
    maYC: find('Mã Yêu Cầu', 'Mã yêu cầu'),
    maDonKH: find('Mã Đơn Khách Hàng', 'Mã đơn khách hàng'),
    shop: find('Tên cửa hàng', 'Tên Cửa Hàng'),
    receiver: find('Người Nhận', 'Người nhận'),
    phone: phoneCol,
    address: addressCol,
    ward: keys.find(k => k.includes('Phường') && k.includes('Xã') && !k.includes('Tạo') && !k.includes('Gửi')) || '',
    district: keys.find(k => k.includes('Quận') && k.includes('Huyện') && !k.includes('Tạo') && !k.includes('Gửi')) || '',
    province: keys.find(k => k.includes('Tỉnh') && k.includes('Thành') && !k.includes('Tạo') && !k.includes('Gửi')) || '',
    cod: find('Thu Hộ'),
    thoiGianTao: find('Thời Gian Tạo', 'Thời gian tạo'),
    pickupDate: find('Thời Gian lấy hàng', 'Thời gian lấy hàng'),
    lastUpdate: find('Cập Nhật Lần Cuối', 'Cập nhật lần cuối'),
    carrier: find('Đơn Vị Vận Chuyển', 'Đơn vị vận chuyển'),
    carrierCode: find('Mã Đơn Đối Tác', 'Mã đơn đối tác'),
  };
}

function parseDelays(note) {
  const delays = [];
  const regex = /(\d{1,2}:\d{2})\s*-\s*(\d{1,2}\/\d{1,2}\/\d{4})\s*Hoãn giao hàng vì:\s*([^\n]+)/g;
  let m; while ((m = regex.exec(note)) !== null) delays.push({ time: m[1], date: m[2], reason: m[3].trim() });
  return delays;
}

function countDelaysInNote(note) {
  const matches = note.match(/Hoãn giao hàng vì:/g);
  if (!matches) return 0;
  let count = matches.length;
  const lanMatches = note.match(/Giao hàng lần (\d+):/g);
  if (lanMatches) { const maxLan = Math.max(...lanMatches.map(s => parseInt(s.match(/\d+/)[0]))); if (maxLan > count) count = maxLan; }
  return count;
}

function extractReasons(note) {
  const reasons = [];
  const regex = /Hoãn giao hàng vì:\s*([^\n]+)/g;
  let m;
  while ((m = regex.exec(note)) !== null) {
    let reason = m[1].trim();
    if (reason.includes('Giao hàng lần')) {
      const subs = reason.match(/(?:Delay giao hàng vì|Không giao được hàng vì)\s+([^G\n]+)/g);
      if (subs) subs.forEach(sr => { const c = sr.replace(/^(Delay giao hàng vì|Không giao được hàng vì)\s+/, '').trim(); if (c) reasons.push(normalizeReason(c)); });
      else reasons.push(normalizeReason(reason));
    } else reasons.push(normalizeReason(reason));
  }
  if (note.includes('Xác nhận hoàn vì')) reasons.push('Xác nhận hoàn hàng');
  return reasons.length > 0 ? reasons : ['Không rõ lý do'];
}

function normalizeReason(r) {
  r = r.replace(/\.\s*Thời gian hẹn:.*$/i, '').replace(/Thời gian hẹn:.*$/i, '').trim();
  if (/Không gọi được|Không liên lạc được|không thể liên hệ|Chặn số|khóa máy|không nghe máy/i.test(r)) return 'Không liên lạc được KH';
  if (/hẹn lại|hẹn ngày|KH hẹn/i.test(r)) return 'KH hẹn lại ngày giao';
  if (/Từ chối.*Không đặt|Không đặt hàng/i.test(r)) return 'Từ chối - Không đặt hàng';
  if (/Đổi ý|không muốn nhận/i.test(r)) return 'Từ chối - Đổi ý không nhận';
  if (/hư hỏng|hư tổn|đóng gói/i.test(r)) return 'Hàng hư hỏng/đóng gói lỗi';
  if (/sai.*địa chỉ/i.test(r)) return 'Sai thông tin địa chỉ';
  if (/sai.*SĐT|sai.*số điện thoại/i.test(r)) return 'Sai thông tin SĐT';
  if (/không thuộc bưu cục/i.test(r)) return 'Sai bưu cục';
  if (/quá số lần/i.test(r)) return 'Quá số lần giao';
  if (/Xác nhận hoàn/i.test(r)) return 'Xác nhận hoàn hàng';
  if (/KH hẹn giao lại quá/i.test(r)) return 'KH hẹn giao lại quá 3 lần';
  if (/Không liên lạc được với KH 3 lần/i.test(r)) return 'Không liên lạc được KH 3 lần';
  return r.substring(0, 60);
}

function assessRisk(delayCount, reasons, daysAge, status) {
  let s = 0;
  if (delayCount >= 4) s += 5; else if (delayCount >= 3) s += 4; else if (delayCount >= 2) s += 2; else s += 1;
  const severe = ['Từ chối - Không đặt hàng','Từ chối - Đổi ý không nhận','Hàng hư hỏng/đóng gói lỗi','Sai thông tin địa chỉ','Sai thông tin SĐT','Xác nhận hoàn hàng','Quá số lần giao','KH hẹn giao lại quá 3 lần','Không liên lạc được KH 3 lần'];
  if (reasons.some(r => severe.includes(r))) s += 3;
  if (daysAge >= 10) s += 3; else if (daysAge >= 5) s += 2; else if (daysAge >= 3) s += 1;
  if (status.includes('Hoãn')) s += 1;
  if (s >= 7) return 'high'; if (s >= 4) return 'medium'; return 'low';
}

function parseViDate(str) { const m = str.match(/(\d{1,2})\/(\d{1,2})\/(\d{4})/); if (!m) return null; return new Date(parseInt(m[3]), parseInt(m[2]) - 1, parseInt(m[1])); }
function parseNumber(v) { if (typeof v === 'number') return v; return parseInt(String(v).replace(/[^\d]/g, '')) || 0; }
function formatCurrency(n) { return n.toLocaleString('vi-VN'); }
function esc(str) { const d = document.createElement('div'); d.textContent = str; return d.innerHTML; }

// ===== DROPDOWNS =====
function populateFilterDropdowns() {
  const shops = [...new Set(allOrders.map(o => o.shop))].filter(Boolean).sort();
  document.getElementById('filterShop').innerHTML = '<option value="">Tất cả</option>' + shops.map(s => `<option value="${esc(s)}">${esc(s)}</option>`).join('');
  const statuses = [...new Set(allOrders.map(o => o.status))].filter(Boolean).sort();
  document.getElementById('filterStatus').innerHTML = '<option value="">Tất cả</option>' + statuses.map(s => `<option value="${esc(s)}">${esc(s)}</option>`).join('');
  const allR = new Set(); allOrders.forEach(o => o.uniqueReasons.forEach(r => allR.add(r)));
  document.getElementById('filterReason').innerHTML = '<option value="">Tất cả</option>' + [...allR].sort().map(r => `<option value="${esc(r)}">${esc(r)}</option>`).join('');
}

// ===== SORT =====
function sortOrders(key, dir) {
  currentSort = { key, dir };
  allOrders.sort((a, b) => {
    let va = a[key], vb = b[key];
    if (typeof va === 'string') { va = va.toLowerCase(); vb = (vb||'').toLowerCase(); }
    if (va < vb) return dir === 'asc' ? -1 : 1;
    if (va > vb) return dir === 'asc' ? 1 : -1;
    if (key !== 'riskScore') return b.riskScore - a.riskScore;
    return 0;
  });
}

// ===== FILTER =====
function applyFilters() {
  const search = (document.getElementById('searchBox')?.value || '').toLowerCase();
  const shopF = document.getElementById('filterShop')?.value || '';
  const statusF = document.getElementById('filterStatus')?.value || '';
  const delayF = document.getElementById('filterDelayCount')?.value || '';
  const reasonF = document.getElementById('filterReason')?.value || '';

  filteredOrders = allOrders.filter(o => {
    if (currentRiskFilter !== 'all' && o.risk !== currentRiskFilter) return false;
    if (search) { const hay = [o.maYC, o.maDonKH, o.maDonDT, o.shop, o.receiver, o.phone, o.fullAddress].join(' ').toLowerCase(); if (!hay.includes(search)) return false; }
    if (shopF && o.shop !== shopF) return false;
    if (statusF && o.status !== statusF) return false;
    if (delayF) { if (delayF === '4+') { if (o.delayCount < 4) return false; } else { if (o.delayCount !== parseInt(delayF)) return false; } }
    if (reasonF && !o.uniqueReasons.includes(reasonF)) return false;
    return true;
  });
  currentPage = 1;
  renderTable();
}

// ===== STATS =====
function renderStats() {
  const total = allOrders.length, high = allOrders.filter(o => o.risk === 'high').length, medium = allOrders.filter(o => o.risk === 'medium').length, low = allOrders.filter(o => o.risk === 'low').length;
  const totalCOD = allOrders.reduce((s, o) => s + o.cod, 0), highCOD = allOrders.filter(o => o.risk === 'high').reduce((s, o) => s + o.cod, 0);
  document.getElementById('statsRow').innerHTML = `
    <div class="stat-card total"><div class="stat-label">Đơn có hoãn giao</div><div class="stat-value">${total}</div><div class="stat-sub">Tổng COD: ${formatCurrency(totalCOD)}đ</div></div>
    <div class="stat-card danger"><div class="stat-label">Nguy cơ cao</div><div class="stat-value">${high}</div><div class="stat-sub">COD rủi ro: ${formatCurrency(highCOD)}đ</div></div>
    <div class="stat-card warning"><div class="stat-label">Cảnh báo</div><div class="stat-value">${medium}</div></div>
    <div class="stat-card safe"><div class="stat-label">Nguy cơ thấp</div><div class="stat-value">${low}</div></div>`;
}

// ===== CHARTS =====
function renderCharts() {
  const distMap = {}; allOrders.forEach(o => { const k = o.delayCount >= 4 ? '4+' : String(o.delayCount); distMap[k] = (distMap[k] || 0) + 1; });
  const distKeys = ['1','2','3','4+'], maxDist = Math.max(...Object.values(distMap), 1), distColors = {'1':'safe','2':'warning','3':'accent','4+':'danger'};
  document.getElementById('delayChart').innerHTML = distKeys.map(k => { const v = distMap[k]||0, pct = Math.round(v/maxDist*100); return `<div class="bar-row"><div class="bar-label">${k==='4+'?'4+ lần':k+' lần'}</div><div class="bar-track"><div class="bar-fill ${distColors[k]}" style="width:${pct}%">${v}</div></div></div>`; }).join('');
  const rMap = {}; allOrders.forEach(o => o.uniqueReasons.forEach(r => { rMap[r] = (rMap[r]||0)+1; }));
  const rEntries = Object.entries(rMap).sort((a,b)=>b[1]-a[1]).slice(0,7), maxR = Math.max(...rEntries.map(e=>e[1]),1);
  document.getElementById('reasonChart').innerHTML = rEntries.map(([reason,count]) => { const pct = Math.round(count/maxR*100); return `<div class="bar-row"><div class="bar-label" title="${reason}">${reason}</div><div class="bar-track"><div class="bar-fill accent" style="width:${pct}%">${count}</div></div></div>`; }).join('');
}

// ===== TABLE =====
function renderTable() {
  const start = (currentPage - 1) * PAGE_SIZE;
  const page = filteredOrders.slice(start, start + PAGE_SIZE);
  const tbody = document.getElementById('tableBody');
  if (!page.length) { tbody.innerHTML = '<tr><td colspan="11" class="no-data">Không có đơn hàng nào phù hợp</td></tr>'; document.getElementById('pagination').innerHTML = ''; return; }

  tbody.innerHTML = page.map((o, i) => {
    const dcClass = o.delayCount >= 3 ? 'dc-high' : o.delayCount >= 2 ? 'dc-med' : 'dc-low';
    const stClass = o.status.includes('Hoãn') ? 'delayed' : 'delivering';
    const reasonsHTML = o.uniqueReasons.map(r => `<span class="reason-tag">${esc(r)}</span>`).join('');
    const timelineHTML = o.delays.length > 0
      ? o.delays.map(d => `<div class="timeline-item">${d.time} - ${d.date}<br>${esc(d.reason)}</div>`).join('')
      : '<span style="color:var(--text-muted);font-size:11px">Chi tiết trong ghi chú</span>';

    // Build copy text for order detail
    const copyText = `Mã đơn: ${o.maDonDT}\nTên: ${o.receiver} - SĐT: ${o.phone}\nĐC: ${o.fullAddress}`;
    const safeText = copyText.replace(/\\/g,'\\\\').replace(/'/g,"\\'").replace(/\n/g,'\\n');

    return `<tr class="risk-${o.risk}">
      <td>${start+i+1}</td>
      <td style="font-weight:600;font-size:12px;white-space:nowrap;">${esc(o.maYC)}</td>
      <td style="font-size:12px;">${esc(o.shop)}</td>
      <td class="order-detail">
        <div class="od-line"><span class="od-label">Mã đơn:</span> <span class="od-value">${esc(o.maDonDT)}</span></div>
        <div class="od-line"><span class="od-label">Tên:</span> <span class="od-value">${esc(o.receiver)}</span> - <span class="od-label">SĐT:</span> <span class="od-value">${esc(o.phone)}</span></div>
        <div class="od-line"><span class="od-label">ĐC:</span> <span class="od-value">${esc(o.fullAddress)}</span></div>
        <button class="copy-btn" onclick="copyDetail(this,'${safeText}')">📋 Copy</button>
      </td>
      <td><span class="status-badge ${stClass}">${esc(o.status)}</span></td>
      <td style="text-align:center;"><span class="delay-count ${dcClass}">${o.delayCount}</span></td>
      <td style="font-size:12px;white-space:nowrap;">${esc(o.createdDate)}<br><span style="color:var(--text-muted);font-size:10px">${o.daysAge} ngày trước</span></td>
      <td class="reason-cell">${reasonsHTML}</td>
      <td class="timeline-cell"><div class="timeline">${timelineHTML}</div></td>
      <td><span class="risk-badge ${o.risk}"><span class="risk-dot"></span>${o.risk==='high'?'Cao':o.risk==='medium'?'Trung bình':'Thấp'}</span></td>
      <td style="text-align:right;font-size:12px;white-space:nowrap;">${formatCurrency(o.cod)}đ</td>
    </tr>`;
  }).join('');
  renderPagination();
}

function copyDetail(btn, text) {
  const decoded = text.replace(/\\n/g, '\n').replace(/\\'/g, "'");
  navigator.clipboard.writeText(decoded).then(() => {
    btn.classList.add('copied'); btn.innerHTML = '✓ Đã copy';
    const toast = document.getElementById('toast'); toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 1800);
    setTimeout(() => { btn.classList.remove('copied'); btn.innerHTML = '📋 Copy'; }, 2000);
  });
}

function renderPagination() {
  const tp = Math.ceil(filteredOrders.length / PAGE_SIZE);
  if (tp <= 1) { document.getElementById('pagination').innerHTML = ''; return; }
  let h = `<button class="page-btn" ${currentPage===1?'disabled':''} onclick="goPage(${currentPage-1})">‹</button>`;
  for (let p=1;p<=tp;p++) { if (p===1||p===tp||Math.abs(p-currentPage)<=2) h+=`<button class="page-btn ${p===currentPage?'active':''}" onclick="goPage(${p})">${p}</button>`; else if (Math.abs(p-currentPage)===3) h+=`<span class="page-info">...</span>`; }
  h+=`<button class="page-btn" ${currentPage===tp?'disabled':''} onclick="goPage(${currentPage+1})">›</button><span class="page-info">${filteredOrders.length} đơn</span>`;
  document.getElementById('pagination').innerHTML = h;
}
function goPage(p) { currentPage=p; renderTable(); document.querySelector('.table-wrapper').scrollIntoView({behavior:'smooth',block:'start'}); }

// ===== EVENTS =====
document.getElementById('searchBox').addEventListener('input', () => applyFilters());
document.getElementById('filterShop').addEventListener('change', () => applyFilters());
document.getElementById('filterStatus').addEventListener('change', () => applyFilters());
document.getElementById('filterDelayCount').addEventListener('change', () => applyFilters());
document.getElementById('filterReason').addEventListener('change', () => applyFilters());

document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active'); currentRiskFilter = btn.dataset.filter; applyFilters();
  });
});

document.getElementById('btnReset').addEventListener('click', () => {
  document.getElementById('searchBox').value = '';
  document.getElementById('filterShop').value = '';
  document.getElementById('filterStatus').value = '';
  document.getElementById('filterDelayCount').value = '';
  document.getElementById('filterReason').value = '';
  currentRiskFilter = 'all';
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  document.querySelector('.filter-btn[data-filter="all"]').classList.add('active');
  applyFilters();
});

document.querySelectorAll('th[data-sort]').forEach(th => {
  th.addEventListener('click', () => {
    const key = th.dataset.sort;
    const dir = currentSort.key === key && currentSort.dir === 'desc' ? 'asc' : 'desc';
    document.querySelectorAll('th').forEach(t => t.classList.remove('sorted'));
    th.classList.add('sorted'); th.querySelector('.sort-icon').textContent = dir === 'desc' ? '▼' : '▲';
    sortOrders(key, dir); applyFilters();
  });
});

// ===== EXPORT =====
document.getElementById('exportBtn').addEventListener('click', () => {
  const data = filteredOrders.map((o, i) => ({
    'STT': i + 1,
    'Mã Yêu Cầu': o.maYC,
    'Mã Đơn KH': o.maDonKH,
    'Mã Đơn': o.maDonDT,
    'Trạng Thái': o.status,
    'Thời Gian Lấy Hàng': o.pickupDate,
    'Thu Hộ': o.cod,
    'Người Nhận': o.receiver,
    'SĐT': o.phone,
    'Địa Chỉ': o.address,
    'Phường/Xã': o.ward,
    'Quận/Huyện': o.district,
    'Tỉnh/Thành': o.province,
    'Số Lần Hoãn': o.delayCount,
    'Nguy Cơ': o.risk === 'high' ? 'CAO' : o.risk === 'medium' ? 'TRUNG BÌNH' : 'THẤP',
  }));
  const ws = XLSX.utils.json_to_sheet(data);
  ws['!cols'] = [{wch:5},{wch:18},{wch:18},{wch:20},{wch:18},{wch:22},{wch:14},{wch:20},{wch:14},{wch:35},{wch:18},{wch:18},{wch:18},{wch:12},{wch:14}];
  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, 'Phân Tích Hoãn Giao');
  XLSX.writeFile(wb, 'phan_tich_hoan_giao_hang.xlsx');
});
</script>
</body>
</html>
