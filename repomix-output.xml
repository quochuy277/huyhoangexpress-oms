        </div>
      </div>

      {/* C2: High Risk */}
      <div className="bg-white p-5 rounded-xl border border-red-100 border-l-4 border-l-red-500 shadow-sm relative overflow-hidden flex flex-col justify-between group hover:border-red-200 transition-colors">
